#include <stdio.h>
#include <string.h>

int main() {
    char cipher[500];

    printf("Enter Ciphertext: ");
    scanf("%s",cipher);

    printf("\nTop 10 Possible Plaintexts:\n");

    for(int key=0; key<10; key++) {
        printf("Key %d : ",key);

        for(int i=0;i<strlen(cipher);i++) {
            char ch=cipher[i];

            if(ch>='A'&&ch<='Z')
                printf("%c",((ch-'A'-key+26)%26)+'A');
            else
                printf("%c",ch);
        }
        printf("\n");
    }
}
