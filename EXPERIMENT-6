#include <stdio.h>

int gcd(int a, int b)
{
    while(b != 0)
    {
        int t = b;
        b = a % b;
        a = t;
    }
    return a;
}

int modInverse(int a, int m)
{
    for(int x = 1; x < m; x++)
        if((a * x) % m == 1)
            return x;
    return -1;
}

int main()
{
    int p1 = 'E' - 'A';   // 4
    int p2 = 'T' - 'A';   // 19

    int c1 = 'B' - 'A';   // 1
    int c2 = 'U' - 'A';   // 20

    int a, b;

    for(a = 1; a < 26; a++)
    {
        if(gcd(a,26) != 1)
            continue;

        b = (c1 - a*p1) % 26;
        if(b < 0) b += 26;

        if(((a*p2 + b) % 26) == c2)
        {
            printf("Possible Key:\n");
            printf("a = %d\n", a);
            printf("b = %d\n", b);
        }
    }

    return 0;
}
