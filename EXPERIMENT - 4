#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char text[100], key[100];
    int i, j = 0;

    printf("Enter plaintext: ");
    scanf("%s", text);

    printf("Enter key: ");
    scanf("%s", key);

    int len = strlen(key);

    for(i=0;text[i]!='\0';i++) {
        if(isalpha(text[i])) {
            int shift = toupper(key[j % len]) - 'A';
            text[i] = ((toupper(text[i]) - 'A' + shift) % 26) + 'A';
            j++;
        }
    }

    printf("Ciphertext: %s\n", text);
    return 0;
}
