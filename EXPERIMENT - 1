#include <stdio.h>
#include <ctype.h>

int main() {
    char text[100];
    int key, i;

    printf("Enter plaintext: ");
    gets(text);

    printf("Enter key (1-25): ");
    scanf("%d", &key);

    for(i = 0; text[i] != '\0'; i++) {
        if(isalpha(text[i])) {
            char base = isupper(text[i]) ? 'A' : 'a';
            text[i] = (text[i] - base + key) % 26 + base;
        }
    }

    printf("Ciphertext: %s\n", text);
    return 0;
}
