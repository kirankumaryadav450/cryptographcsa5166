#include <stdio.h>
#include <string.h>

int main() {
    char text[1000];
    int freq[26]={0};

    printf("Enter Ciphertext:\n");
    gets(text);

    for(int i=0;text[i];i++)
        if(text[i]>='A'&&text[i]<='Z')
            freq[text[i]-'A']++;

    printf("\nLetter Frequencies:\n");

    for(int i=0;i<26;i++)
        printf("%c : %d\n",'A'+i,freq[i]);

    printf("\nMost frequent letters are likely E,T,A,O,N.\n");

    return 0;
}
