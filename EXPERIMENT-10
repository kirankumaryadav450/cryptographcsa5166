#include <stdio.h>
#include <string.h>

char m[5][5]={
{'M','F','H','I','K'},
{'U','N','O','P','Q'},
{'Z','V','W','X','Y'},
{'E','L','A','R','G'},
{'D','S','T','B','C'}
};

void pos(char ch,int *r,int *c){
    if(ch=='J') ch='I';
    for(int i=0;i<5;i++)
        for(int j=0;j<5;j++)
            if(m[i][j]==ch){*r=i;*c=j;}
}

int main(){
    char pt[]="MUSTSEEYOUOVERCADOGANWESTCOMINGATONCE";

    for(int i=0;i<strlen(pt);i+=2){
        int r1,c1,r2,c2;
        pos(pt[i],&r1,&c1);
        pos(pt[i+1],&r2,&c2);

        if(r1==r2)
            printf("%c%c",m[r1][(c1+1)%5],
                            m[r2][(c2+1)%5]);
        else if(c1==c2)
            printf("%c%c",m[(r1+1)%5][c1],
                            m[(r2+1)%5][c2]);
        else
            printf("%c%c",m[r1][c2],
                            m[r2][c1]);
    }
}
