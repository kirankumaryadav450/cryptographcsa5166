#include <stdio.h>
#include <string.h>

int main()
{
    char cipher[1000];
    char map[256];
    int i;

    for(i = 0; i < 256; i++)
        map[i] = '?';

    /* Example mappings discovered during analysis */
    map['5'] = 'a';
    map['3'] = 'g';
    map['8'] = 'e';
    map['‡'] = 't';
    map['†'] = 'h';

    printf("Enter ciphertext:\n");
    gets(cipher);

    printf("\nDecrypted Text:\n");

    for(i = 0; cipher[i] != '\0'; i++)
    {
        if(map[(unsigned char)cipher[i]] != '?')
            printf("%c", map[(unsigned char)cipher[i]]);
        else
            printf("%c", cipher[i]);
    }

    return 0;
}
